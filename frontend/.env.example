# ─── Frontend Environment Variables Example ────────────────────────────────────
# Copy to .env.local for local development.
# For Vercel production, set these in Vercel Dashboard -> Project -> Settings -> Environment Variables

# ── API connection ───────────────────────────────────────────────────────────────
# Local dev: points directly to Flask dev server
VITE_API_BASE_URL=http://localhost:5000/api

# Production (Vercel): points to your Render backend service
# VITE_API_BASE_URL=https://contractshield-backend.onrender.com/api

# ── WebSocket / SocketIO ─────────────────────────────────────────────────────────
# Local dev: Flask dev server
VITE_SOCKET_URL=http://localhost:5000

# Production (Vercel): Render backend
# VITE_SOCKET_URL=https://contractshield-backend.onrender.com
