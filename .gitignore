# ─── Python / Backend ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
*.pyc

# Virtual environments
venv/
env/
.venv/
ENV/
backend/venv/
backend/env/

# Environment / secrets — NEVER commit these
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# SQLite databases
*.db
*.sqlite
*.sqlite3
backend/instance/

# Uploaded files
backend/uploads/*
!backend/uploads/.gitkeep

# Flask migrations — keep the folder, it's needed
# Uncomment to exclude:
# backend/migrations/

# ─── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# ─── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/

# ─── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ─── Tool-specific ─────────────────────────────────────────────────────────────
.orchids/
docker-compose.override.yml

# ─── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.eggs/
.eggs/
