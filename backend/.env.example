# ─── Backend Environment Variables Example ─────────────────────────────────────
# Copy to .env for local development, or set directly in Render dashboard for production.

# Flask core
FLASK_APP=run.py
FLASK_ENV=development          # change to "production" on Render

# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# ── Database ────────────────────────────────────────────────────────────────────
# Local development (SQLite, no setup needed):
DATABASE_URL=sqlite:///contract_analyzer.db

# Supabase PostgreSQL (production):
# 1. Go to supabase.com -> New project -> Settings -> Database
# 2. Copy "Connection string" (URI format) from the "Connection pooling" tab
#    Use the "Transaction" mode URL (port 6543) for serverless/free tier:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── File uploads ────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# ── NLP ─────────────────────────────────────────────────────────────────────────
SPACY_MODEL=en_core_web_sm

# ── Groq AI API ─────────────────────────────────────────────────────────────────
# Get free API key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile

# ── CORS ─────────────────────────────────────────────────────────────────────────
# Local:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Production (set in Render dashboard):
# CORS_ORIGINS=https://your-app.vercel.app

# ── Debug flags ─────────────────────────────────────────────────────────────────
DEBUG=True
TESTING=False
